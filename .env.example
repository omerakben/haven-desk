# Copy to .env only to override defaults. The default chat model is the light
# tier (gemma4:e4b, ~4 GB) everywhere — picked for RAM headroom, especially when
# the full Docker stack (Open WebUI) runs alongside. Switch live anytime in the
# cockpit: Settings → Model.
#
# Uncomment to use the heavier, higher-quality 12B instead:
# OLLAMA_MODEL=gemma4:12b-mlx

# Models scripts/pull-models.sh ensures are present (both tiers + embeddings):
OLLAMA_LIGHT_MODEL=gemma4:e4b
EMBED_MODEL=embeddinggemma

# Local (non-Docker) cockpit dev: where the SQLite file lives.
DATABASE_URL="file:./dev.db"
