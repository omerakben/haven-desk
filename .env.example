# Copy to .env only to override defaults. Out of the box the model differs by
# how you run the app (and you can always switch live in the cockpit:
# Settings → Model):
#   - Local cockpit dev (npm run dev):                 gemma4:12b-mlx  (quality)
#   - Full Docker stack (docker compose / ./start.sh): gemma4:e4b      (light)
#     ...because Open WebUI + a 12B model can nearly fill 48 GB of RAM.
#
# Uncomment to FORCE one chat model in both paths:
# OLLAMA_MODEL=gemma4:12b-mlx

# Models scripts/pull-models.sh ensures are present (both tiers + embeddings):
OLLAMA_LIGHT_MODEL=gemma4:e4b
EMBED_MODEL=embeddinggemma

# Local (non-Docker) cockpit dev: where the SQLite file lives.
DATABASE_URL="file:./dev.db"
